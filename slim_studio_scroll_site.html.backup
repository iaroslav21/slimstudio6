
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&family=Montserrat:wght@500;600;700&family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
/* Typography System - Modern Geometric */
--font-heading:'Sora','Poppins','Montserrat',sans-serif;
--font-body:'Inter','Open Sans',sans-serif;
--font-accent:'Poppins',sans-serif;
/* Dark Luxury Base */
--bg-dark:#0B0D10;
--bg-surface:#151922;
--bg-card:#1C212C;
--bg-hover:#252A35;
/* Premium Text */
--text:#FFFFFF;
--text-secondary:#C9CAD0;
--text-muted:#8A8E99;
/* Premium Accent Colors - Gold Muted & Luxury System */
--accent-primary:#C8A24A;
--accent-secondary:#7EE0C3;
--accent-light:#E8D5B1;
--success:#5B8A72;
--danger:#EF4444;
/* Legacy compatibility */
--ivory:#F8F4EE;
--champagne:#E8D8C4;
--muted:#8A8E99;
--white:#FFFFFF;
/* Visual Hierarchy - Soft Realistic Shadows */
--shadow-sm:0 4px 12px rgba(0,0,0,0.25);
--shadow-md:0 12px 32px rgba(0,0,0,0.35);
--shadow-lg:0 20px 48px rgba(0,0,0,0.4);
--shadow-xl:0 32px 64px rgba(0,0,0,0.45);
/* Spacing System */
--spacing-xs:4px;
--spacing-sm:8px;
--spacing-md:16px;
--spacing-lg:24px;
--spacing-xl:32px;
}

/* ANIMATIONS - Premium Motion Design */
@keyframes slideUpIn{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes blurIn{from{opacity:0;filter:blur(10px)}to{opacity:1;filter:blur(0)}}
@keyframes scaleHover{from{transform:scale(1)}to{transform:scale(1.05)}}
@keyframes glowHover{from{box-shadow:var(--shadow-sm)}to{box-shadow:var(--shadow-xl)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.8}}
@keyframes slideInLeft{from{opacity:0;transform:translateX(-30px)}to{opacity:1;transform:translateX(0)}}
@keyframes slideInRight{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}

/* Scroll Reveal Animation - Applied to content sections */
.scroll-reveal{opacity:0;animation:slideUpIn 0.8s cubic-bezier(0.34,1.56,0.64,1) forwards}
.scroll-reveal.visible{opacity:1}

/* Stagger animation for grid items */
.scroll-reveal:nth-child(1){animation-delay:0s}
.scroll-reveal:nth-child(2){animation-delay:0.15s}
.scroll-reveal:nth-child(3){animation-delay:0.3s}
.scroll-reveal:nth-child(4){animation-delay:0.45s}
.scroll-reveal:nth-child(5){animation-delay:0.6s}
.scroll-reveal:nth-child(6){animation-delay:0.75s}

*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg-dark);color:var(--text);line-height:1.6;overflow-x:hidden;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
.nav{display:flex;align-items:center;justify-content:space-between;padding:18px 48px;backdrop-filter:blur(12px);background:rgba(11,13,16,0.85);border-bottom:1px solid rgba(200,162,74,0.15);position:sticky;top:0;z-index:100;box-shadow:0 8px 32px rgba(0,0,0,0.1)}
.nav-logo{font-family:var(--font-heading);font-size:24px;font-weight:700;letter-spacing:2px;color:var(--text)}
.nav-logo small{display:block;font-size:9px;letter-spacing:3px;color:var(--muted);font-weight:400;margin-top:2px}
.nav-links{display:flex;gap:32px}
.nav-link{font-family:var(--font-body);font-size:13px;color:var(--muted);cursor:pointer;padding:8px 0;border-bottom:2px solid transparent;text-decoration:none;transition:all 0.3s ease;font-weight:500}
.nav-link:hover{color:var(--accent-primary);border-bottom-color:var(--accent-primary)}
.nav-cta{background:var(--accent-primary);color:var(--white);border:none;padding:12px 28px;border-radius:8px;font-family:var(--font-accent);font-size:13px;cursor:pointer;font-weight:600;transition:all 0.3s ease;box-shadow:0 4px 12px rgba(200,162,74,0.3);letter-spacing:0.5px}
.nav-cta:hover{transform:translateY(-2px);box-shadow:0 8px 20px rgba(16,185,129,0.4)}
.lang-toggle{display:flex;gap:6px;border:1px solid rgba(200,162,74,0.2);border-radius:8px;padding:4px}
.lang-btn{background:transparent;border:1px solid transparent;color:var(--text);font-family:var(--font-accent);font-size:13px;font-weight:600;padding:8px 12px;cursor:pointer;border-radius:6px;transition:all 0.3s ease;letter-spacing:0.5px}
.lang-btn:hover{background:rgba(200,162,74,0.1)}
.lang-btn.active{background:rgba(200,162,74,0.2);border-color:var(--accent-primary)}

.sec{padding:80px 48px}
.sec-alt{background:var(--bg-surface)}
.sec-title{font-family:var(--font-heading);text-align:center;font-size:48px;font-weight:700;margin-bottom:12px;color:var(--text);letter-spacing:-0.5px}
.sec-sub{text-align:center;font-size:16px;color:var(--muted);margin-bottom:48px;font-family:var(--font-body);font-weight:400;letter-spacing:0.3px}

.hero{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;padding:100px 48px;max-width:1400px;margin:0 auto;background:linear-gradient(135deg,var(--bg-dark) 0%,var(--bg-surface) 100%);position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;right:0;width:500px;height:500px;background:radial-gradient(circle,rgba(200,162,74,0.1) 0%,transparent 70%);border-radius:50%;pointer-events:none}
.hero-content{display:flex;flex-direction:column;gap:20px}
.hero-badge{display:inline-block;background:rgba(200,162,74,0.1);border:1px solid var(--accent-primary);color:var(--accent-primary);font-size:10px;letter-spacing:1.5px;padding:10px 20px;border-radius:24px;align-self:flex-start;font-weight:700;text-transform:uppercase;font-family:var(--font-accent)}
.hero h1{font-family:var(--font-heading);font-size:56px;font-weight:700;color:var(--text);line-height:1.15;margin-bottom:8px;max-width:500px;letter-spacing:-1px}
.hero h1 em{font-style:normal;color:var(--accent-primary);position:relative}
.hero-p{font-family:var(--font-body);font-size:16px;color:var(--text-secondary);max-width:480px;line-height:1.8;font-weight:400;margin:0}
.hero-btns{display:flex;gap:16px;flex-wrap:wrap;margin-top:8px}
.btn-p{background:var(--accent-primary);color:var(--white);border:none;padding:14px 36px;border-radius:8px;font-family:var(--font-accent);font-size:14px;cursor:pointer;font-weight:600;transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1);box-shadow:var(--shadow-md);letter-spacing:0.5px;will-change:transform,box-shadow;text-transform:capitalize}
.btn-p:hover{transform:translateY(-4px) scale(1.02);box-shadow:0 16px 40px rgba(200,162,74,0.3)}
.btn-s{background:transparent;color:var(--accent-primary);border:2px solid var(--accent-primary);padding:12px 36px;border-radius:8px;font-family:var(--font-accent);font-size:14px;cursor:pointer;font-weight:600;transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1);will-change:all;text-transform:capitalize}
.btn-s:hover{background:var(--accent-primary);color:var(--white);transform:scale(1.02)}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:32px;padding-top:32px;border-top:1px solid rgba(255,255,255,0.1)}
.hero-stat strong{display:block;font-family:var(--font-accent);font-size:32px;font-weight:700;color:var(--accent-primary);margin-bottom:8px;letter-spacing:-0.5px}
.hero-stat span{font-family:var(--font-body);font-size:11px;color:var(--text-muted);letter-spacing:1px;font-weight:500;text-transform:uppercase}
.hero-visual{grid-column:2;height:500px;background:linear-gradient(135deg,rgba(200,162,74,0.1) 0%,rgba(126,224,195,0.1) 100%);border-radius:24px;display:flex;align-items:center;justify-content:center;font-size:120px}

.grid3{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;max-width:1200px;margin:0 auto}
.grid2{display:grid;grid-template-columns:repeat(auto-fit,minmax(380px,1fr));gap:24px;max-width:1000px;margin:0 auto}
.card{background:var(--bg-card);border:1px solid rgba(16,185,129,0.2);border-radius:24px;padding:32px;transition:all 0.4s cubic-bezier(0.34,1.56,0.64,1);box-shadow:var(--shadow-sm);will-change:transform,box-shadow}
.card:hover{transform:translateY(-12px) scale(1.02);border-color:var(--accent-primary);box-shadow:0 20px 48px rgba(200,162,74,0.2)}

.svc-icon{width:56px;height:56px;background:rgba(16,185,129,0.1);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:20px;font-size:28px;transition:all 0.3s ease}
.svc-card:hover .svc-icon{background:var(--accent-primary);transform:scale(1.1)}
.svc-card h3{font-family:var(--font-heading);font-size:18px;font-weight:700;margin-bottom:12px;color:var(--text)}
.svc-card p{font-size:14px;color:var(--muted);line-height:1.7}
.svc-price{margin-top:16px;font-family:var(--font-accent);font-size:13px;font-weight:700;color:var(--accent-primary);letter-spacing:0.5px}

.t-stars{color:var(--accent-primary);font-size:14px;margin-bottom:12px;letter-spacing:1px}
.t-text{font-family:var(--font-body);font-size:15px;color:var(--text);line-height:1.8;margin-bottom:18px;font-style:italic;font-weight:400}
.t-author{display:flex;align-items:center;gap:12px}
.avatar{width:42px;height:42px;border-radius:50%;background:var(--accent-primary);display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-size:12px;font-weight:600;color:var(--white);flex-shrink:0;box-shadow:var(--shadow-sm)}
.t-name{font-family:var(--font-body);font-size:13px;font-weight:600;color:var(--text)}
.t-result{font-size:12px;color:var(--accent-primary);letter-spacing:0.3px;font-weight:500}

.ba-card{border:1px solid rgba(16,185,129,0.15);border-radius:20px;overflow:hidden;background:var(--bg-card);box-shadow:var(--shadow-sm);transition:all 0.3s ease}
.ba-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
.ba-imgs{display:grid;grid-template-columns:1fr 1fr}
.ba-img{height:140px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:6px;font-size:11px;font-weight:500}
.ba-before{background:#2a2a2a;color:var(--muted)}
.ba-after{background:rgba(91,138,114,0.1);color:var(--success)}
.ba-info{padding:20px}
.ba-name{font-family:var(--font-heading);font-size:14px;font-weight:700;color:var(--text)}
.ba-res{font-size:12px;color:var(--accent-primary);margin-top:4px;font-weight:600}
.ba-time{font-size:11px;color:var(--muted);margin-top:4px}

.faq-item{border-bottom:1px solid rgba(16,185,129,0.1)}
.faq-q{padding:20px 0;font-family:var(--font-body);font-size:14px;font-weight:600;cursor:pointer;display:flex;justify-content:space-between;align-items:center;color:var(--text);transition:all 0.3s ease}
.faq-q:hover{color:var(--accent-primary)}
.faq-a{padding-bottom:20px;font-family:var(--font-body);font-size:14px;color:var(--muted);line-height:1.8;display:none;font-weight:400}
.faq-a.open{display:block}

.form-wrap{max-width:620px;margin:0 auto;background:var(--bg-card);border:1px solid rgba(16,185,129,0.2);border-radius:20px;padding:40px;box-shadow:var(--shadow-md)}
.form-title{font-family:var(--font-heading);font-size:26px;font-weight:700;margin-bottom:8px;color:var(--text)}
.form-sub{font-size:13px;color:var(--muted);margin-bottom:28px;font-family:var(--font-body)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px}
.fg{margin-bottom:16px}
.fg label{display:block;font-family:var(--font-accent);font-size:12px;color:var(--text);margin-bottom:6px;font-weight:700;letter-spacing:0.3px;text-transform:capitalize}
.fg input,.fg select,.fg textarea{width:100%;padding:12px 14px;font-family:var(--font-body);font-size:14px;border:1px solid rgba(16,185,129,0.2);border-radius:8px;background:var(--bg-surface);color:var(--text);transition:all 0.3s ease}
.fg input::placeholder,.fg textarea::placeholder{color:var(--muted)}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--accent-primary);box-shadow:0 0 0 3px rgba(16,185,129,0.1)}
.ferr{font-size:12px;color:#C41E3A;margin-top:4px;display:none;font-weight:500;font-family:var(--font-body)}
.ferr.show{display:block}
.f-submit{width:100%;background:var(--accent-primary);color:var(--white);border:none;padding:14px;border-radius:8px;font-family:var(--font-accent);font-size:14px;font-weight:600;cursor:pointer;margin-top:12px;transition:all 0.3s ease;letter-spacing:0.5px;box-shadow:var(--shadow-md);text-transform:capitalize}
.f-submit:hover:not(:disabled){transform:translateY(-2px);box-shadow:var(--shadow-lg)}
.f-submit:disabled{opacity:0.6;cursor:not-allowed}
.consent-row{display:flex;gap:10px;align-items:flex-start;margin-bottom:16px}
.consent-row input{width:18px;height:18px;border:1px solid rgba(16,185,129,0.3);border-radius:4px;cursor:pointer;accent-color:var(--accent-primary)}
.consent-row span{font-size:12px;color:var(--muted);line-height:1.6;font-family:var(--font-body)}
.consent-row a{color:var(--accent-primary);text-decoration:none;font-weight:600}
.f-success{text-align:center;padding:40px;display:none}
.f-success.show{display:block}

.booking-wrap{max-width:620px;margin:0 auto}
.slots-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin:24px 0}
.slot{border:1px solid rgba(16,185,129,0.2);border-radius:12px;padding:14px;text-align:center;cursor:pointer;transition:all 0.3s ease;background:var(--bg-surface);box-shadow:var(--shadow-sm)}
.slot:hover:not(.full){border-color:var(--accent-primary);background:rgba(16,185,129,0.05)}
.slot.selected{border-color:var(--accent-primary);background:rgba(16,185,129,0.1)}
.slot.full{opacity:0.4;cursor:not-allowed}
.slot-date{font-family:var(--font-accent);font-size:13px;font-weight:700;color:var(--text)}
.slot-time{font-size:12px;color:var(--muted);margin-top:4px}
.slot-avail{font-family:var(--font-accent);font-size:11px;margin-top:6px;font-weight:700;letter-spacing:0.5px}
.avail-ok{color:var(--success)}.avail-few{color:#D97706}.avail-none{color:#C41E3A}
.time-pill{border:1px solid rgba(16,185,129,0.2);border-radius:8px;padding:10px 18px;cursor:pointer;font-family:var(--font-accent);font-size:13px;display:inline-block;transition:all 0.3s ease;background:var(--bg-surface);margin:4px;font-weight:600}
.time-pill:hover{border-color:var(--accent-primary);background:rgba(16,185,129,0.05)}
.time-pill.sel{border-color:var(--accent-primary);background:var(--accent-primary);color:var(--white);font-weight:600}
.book-confirm{background:rgba(91,138,114,0.15);border:1px solid var(--success);border-radius:12px;padding:18px;margin-top:20px;display:none}
.book-confirm.show{display:block}

.calc-tabs{display:flex;gap:12px;margin-bottom:28px;justify-content:center}
.ctab{padding:10px 20px;border-radius:8px;border:1px solid rgba(16,185,129,0.2);font-family:var(--font-accent);font-size:13px;cursor:pointer;color:var(--muted);background:transparent;transition:all 0.3s ease;font-weight:700}
.ctab:hover{border-color:var(--accent-primary);color:var(--accent-primary)}
.ctab.active{background:var(--accent-primary);color:var(--white);border-color:var(--accent-primary)}
.calc-block{display:none;max-width:540px;margin:0 auto}
.calc-block.active{display:block;animation:fadeIn 0.3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.calc-result{background:linear-gradient(135deg,rgba(16,185,129,0.08) 0%,rgba(16,185,129,0.05) 100%);border:1px solid rgba(16,185,129,0.25);border-radius:16px;padding:28px;text-align:center;margin-top:20px}
.calc-val{font-family:var(--font-accent);font-size:48px;font-weight:700;color:var(--accent-primary);letter-spacing:-0.5px}
.calc-label{font-size:12px;color:var(--muted);margin-top:6px;font-family:var(--font-body);font-weight:500;letter-spacing:0.5px}
.calc-interp{font-family:var(--font-accent);font-size:14px;font-weight:700;margin-top:8px}
.calc-interp{color:var(--success)}

.quiz-prog{height:6px;background:rgba(16,185,129,0.1);border-radius:3px;margin-bottom:28px;overflow:hidden}
.quiz-prog-bar{height:6px;background:var(--accent-primary);border-radius:3px;transition:width 0.4s ease}
.quiz-step{display:none;max-width:560px;margin:0 auto;animation:slideUp 0.3s ease}
@keyframes slideUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.quiz-step.active{display:block}
.quiz-q{font-family:var(--font-heading);font-size:32px;font-weight:700;margin-bottom:12px;color:var(--text);letter-spacing:-0.5px}
.quiz-sub{font-family:var(--font-body);font-size:15px;color:var(--muted);margin-bottom:24px;font-weight:400}
.quiz-opts{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.qopt{border:1px solid rgba(16,185,129,0.2);border-radius:12px;padding:16px;cursor:pointer;font-family:var(--font-accent);font-size:14px;text-align:center;transition:all 0.3s ease;background:var(--bg-surface);font-weight:600;box-shadow:var(--shadow-sm)}
.qopt:hover{border-color:var(--accent-primary);transform:translateY(-2px);box-shadow:var(--shadow-md)}
.qopt.sel{border-color:var(--accent-primary);background:var(--accent-primary);color:var(--white);font-weight:600}
.quiz-nav{display:flex;justify-content:space-between;align-items:center;margin-top:28px;gap:12px}
.qnext{background:var(--accent-primary);color:var(--white);border:none;padding:12px 28px;border-radius:8px;font-family:var(--font-accent);font-size:14px;cursor:pointer;font-weight:600;transition:all 0.3s ease;letter-spacing:0.5px;box-shadow:var(--shadow-md);text-transform:capitalize}
.qnext:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg)}
.qback{background:transparent;color:var(--muted);border:1px solid rgba(16,185,129,0.2);padding:12px 28px;border-radius:8px;font-family:var(--font-accent);font-size:14px;cursor:pointer;font-weight:600;transition:all 0.3s ease;text-transform:capitalize}
.qback:hover{border-color:var(--accent-primary);color:var(--accent-primary)}

.blog-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:24px;max-width:1200px;margin:0 auto}
.blog-card{border:1px solid rgba(16,185,129,0.15);border-radius:16px;overflow:hidden;cursor:pointer;transition:all 0.3s ease;background:var(--bg-card);box-shadow:var(--shadow-sm)}
.blog-card:hover{transform:translateY(-8px);border-color:var(--accent-primary);box-shadow:var(--shadow-md)}
.blog-img{height:160px;background:linear-gradient(135deg,rgba(16,185,129,0.08) 0%,rgba(16,185,129,0.05) 100%);display:flex;align-items:center;justify-content:center;font-size:48px;transition:all 0.3s ease}
.blog-card:hover .blog-img{background:linear-gradient(135deg,rgba(16,185,129,0.12) 0%,rgba(16,185,129,0.08) 100%)}
.blog-body{padding:20px}
.blog-tag{font-family:var(--font-accent);font-size:10px;letter-spacing:1px;color:var(--accent-primary);font-weight:700;text-transform:uppercase;margin-bottom:8px;display:inline-block}
.blog-card h3{font-family:var(--font-heading);font-size:16px;font-weight:700;line-height:1.5;margin-bottom:10px;color:var(--text)}
.blog-card p{font-family:var(--font-body);font-size:14px;color:var(--muted);line-height:1.7;font-weight:400}
.blog-date{font-family:var(--font-body);font-size:11px;color:var(--muted);margin-top:12px;font-weight:500;letter-spacing:0.3px}

.dash-metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-bottom:28px}
.metric{background:linear-gradient(135deg,rgba(16,185,129,0.08) 0%,rgba(16,185,129,0.05) 100%);border:1px solid rgba(16,185,129,0.2);border-radius:12px;padding:20px;transition:all 0.3s ease}
.metric:hover{transform:translateY(-4px);box-shadow:var(--shadow-md)}
.metric-val{font-family:var(--font-accent);font-size:36px;font-weight:700;color:var(--accent-primary);letter-spacing:-0.5px}
.metric-label{font-family:var(--font-body);font-size:12px;color:var(--muted);margin-top:6px;font-weight:500;letter-spacing:0.3px}
.metric-up{font-family:var(--font-accent);font-size:11px;color:var(--success);margin-top:6px;font-weight:700}
.crm-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px;align-items:center}
.fbtn{padding:8px 16px;border-radius:20px;font-family:var(--font-accent);font-size:12px;cursor:pointer;border:1px solid rgba(16,185,129,0.2);color:var(--muted);background:transparent;transition:all 0.3s ease;font-weight:700}
.fbtn:hover{border-color:var(--accent-primary);color:var(--accent-primary)}
.fbtn.active{background:var(--accent-primary);color:var(--white);border-color:var(--accent-primary)}
.srch{flex:1;min-width:180px;padding:10px 14px;border:1px solid rgba(16,185,129,0.2);border-radius:8px;font-family:var(--font-body);font-size:13px;background:var(--bg-surface);color:var(--text);transition:all 0.3s ease}
.srch:focus{outline:none;border-color:var(--accent-primary);box-shadow:0 0 0 3px rgba(16,185,129,0.1)}
.srch::placeholder{color:var(--muted)}
.leads-table{width:100%;border-collapse:collapse;font-family:var(--font-body);font-size:13px;table-layout:fixed}
.leads-table th{text-align:left;padding:12px 14px;font-size:11px;font-weight:700;color:var(--text);border-bottom:1px solid rgba(16,185,129,0.15);background:rgba(16,185,129,0.1);letter-spacing:0.3px;text-transform:uppercase;font-family:var(--font-accent)}
.leads-table td{padding:12px 14px;border-bottom:1px solid rgba(16,185,129,0.1);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.leads-table tr:hover td{background:rgba(16,185,129,0.1)}
.sbadge{padding:4px 10px;border-radius:20px;font-family:var(--font-accent);font-size:11px;font-weight:700;display:inline-block;text-align:center;letter-spacing:0.3px}
.s-new{background:rgba(24,95,165,0.1);color:#185FA5}.s-contacted{background:rgba(250,238,218,0.6);color:#854F0B}
.s-scheduled{background:rgba(83,74,183,0.1);color:#534AB7}.s-active{background:rgba(91,138,114,0.1);color:#3B6D11}.s-done{background:rgba(95,94,90,0.1);color:#5F5E5A}
.act-btn{padding:6px 10px;font-family:'Poppins',sans-serif;font-size:11px;border:1px solid rgba(16,185,129,0.2);border-radius:6px;cursor:pointer;color:var(--muted);background:transparent;margin-right:4px;transition:all 0.3s ease;font-weight:600}
.act-btn:hover{border-color:var(--accent-primary);color:var(--accent-primary);background:rgba(16,185,129,0.05)}
.expbtn{background:transparent;border:1px solid rgba(16,185,129,0.2);color:var(--muted);padding:8px 16px;border-radius:8px;font-family:'Poppins',sans-serif;font-size:13px;cursor:pointer;display:inline-flex;align-items:center;gap:6px;transition:all 0.3s ease;font-weight:600}
.expbtn:hover{border-color:var(--accent-primary);color:var(--accent-primary)}

.tg-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:20px;justify-content:center}
.tg-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:20px;font-family:'Poppins',sans-serif;font-size:11px;font-weight:600;background:rgba(24,95,165,0.1);color:#185FA5;letter-spacing:0.3px}

.section-divider{text-align:center;padding:48px 48px 0;font-family:'Poppins',sans-serif;font-size:10px;letter-spacing:3px;color:var(--muted);text-transform:uppercase;border-top:1px solid rgba(16,185,129,0.15);font-weight:600}

.toast{position:fixed;bottom:32px;right:32px;background:var(--text);color:var(--white);padding:14px 24px;border-radius:8px;font-family:'Poppins',sans-serif;font-size:13px;opacity:0;transition:opacity 0.3s ease;pointer-events:none;z-index:999;box-shadow:var(--shadow-lg);font-weight:500;letter-spacing:0.3px}
.toast.show{opacity:1;pointer-events:auto}
.expert-card h3{font-family:var(--font-heading);font-size:20px;font-weight:700;color:var(--text)}
.expert-card p{font-size:13px;color:var(--muted);line-height:1.7;font-family:var(--font-body)}
.pricing-card{text-align:center}
.pricing-card h3{font-family:var(--font-heading);font-size:22px;font-weight:700;color:var(--text);margin-bottom:8px}

/* Professional Photo & Specialist System */
.specialist-section{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:32px;max-width:1200px;margin:0 auto}
.specialist-card{background:var(--bg-card);border:1px solid rgba(16,185,129,0.2);border-radius:24px;overflow:hidden;transition:all 0.3s ease;box-shadow:var(--shadow-md)}
.specialist-card:hover{transform:translateY(-12px);border-color:var(--accent-primary);box-shadow:var(--shadow-xl)}
.specialist-photo{width:100%;height:360px;background:linear-gradient(135deg,rgba(16,185,129,0.1) 0%,rgba(16,185,129,0.08) 100%);display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative}
.specialist-photo img{width:100%;height:100%;object-fit:cover;transition:transform 0.3s ease}
.specialist-card:hover .specialist-photo img{transform:scale(1.05)}
.specialist-info{padding:32px}
.specialist-name{font-family:var(--font-heading);font-size:24px;font-weight:700;color:var(--text);margin-bottom:8px;letter-spacing:-0.5px}
.specialist-title{font-family:var(--font-accent);font-size:12px;color:var(--accent-primary);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px}
.specialist-bio{font-family:var(--font-body);font-size:15px;color:var(--text-secondary);line-height:1.8;margin-bottom:20px}
.specialist-certs{list-style:none;margin:20px 0;padding:16px 0;border-top:1px solid rgba(16,185,129,0.15);border-bottom:1px solid rgba(16,185,129,0.15)}
.specialist-certs li{font-size:13px;color:var(--text);margin:8px 0;padding-left:24px;position:relative}
.specialist-certs li:before{content:'✓';position:absolute;left:0;color:var(--accent-primary);font-weight:700}
.specialist-stats{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin:20px 0;padding:20px 0;border-top:1px solid rgba(16,185,129,0.15)}
.specialist-stat-value{font-family:var(--font-accent);font-size:32px;font-weight:700;color:var(--accent-primary);letter-spacing:-0.5px}
.specialist-stat-label{font-size:12px;color:var(--text-muted);margin-top:4px}
.specialist-btn{width:100%;background:var(--accent-primary);color:var(--white);border:none;padding:14px;border-radius:8px;font-family:var(--font-accent);font-size:14px;cursor:pointer;font-weight:600;transition:all 0.3s ease;box-shadow:var(--shadow-md);margin-top:16px;text-transform:capitalize}
.specialist-btn:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg)}
@media(max-width:768px){
.nav{padding:16px 24px}
.sec{padding:60px 24px}
.hero{grid-template-columns:1fr;gap:32px;padding:80px 24px 60px;max-width:100%}
.hero-visual{grid-column:1;height:300px}
.grid3{gap:16px}
.hero h1{font-size:42px}
.hero-stats{grid-template-columns:repeat(3,1fr);gap:16px}
.sec-title{font-size:36px}
.nav-links{gap:16px;font-size:12px}
}
</style>

