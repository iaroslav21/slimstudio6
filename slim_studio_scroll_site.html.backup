function sc(id){
  var el=document.getElementById(id);
  if(el){
    el.scrollIntoView({behavior:'smooth',block:'start'});
  }
}
function showToast(msg){
  var t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  t.style.animation='slideUp 0.3s ease';
  setTimeout(function(){t.classList.remove('show')},3200);
}
function tFaq(el){
  var a=el.nextElementSibling,sp=el.querySelector('span');
  a.classList.toggle('open');sp.textContent=a.classList.contains('open')?'−':'+';
}
function switchCalc(tab,btn){
  document.querySelectorAll('.ctab').forEach(function(b){b.classList.remove('active')});
  document.querySelectorAll('.calc-block').forEach(function(c){c.classList.remove('active')});
  btn.classList.add('active');
  document.getElementById('calc-'+tab).classList.add('active');
}
function calcIMC(){
  var h=parseFloat(document.getElementById('ih').value)/100;
  var w=parseFloat(document.getElementById('iw').value);
  if(!h||!w)return;
  var bmi=w/(h*h);
  document.getElementById('imcVal').textContent=bmi.toFixed(1);
  var el=document.getElementById('imcInterp');
  if(bmi<18.5){el.textContent='Subponderal';el.style.color='#185FA5';}
  else if(bmi<25){el.textContent='Greutate normală';el.style.color='#3B6D11';}
  else if(bmi<30){el.textContent='Supraponderal';el.style.color='#BA7517';}
  else{el.textContent='Obezitate';el.style.color='#A32D2D';}
}
function calcCal(){
  var age=parseFloat(document.getElementById('ca').value)||30;
  var w=parseFloat(document.getElementById('cw').value)||65;
  var h=parseFloat(document.getElementById('ch').value)||165;
  var act=parseFloat(document.getElementById('cact').value)||1.375;
  var bmr=Math.round(10*w+6.25*h-5*age-161);
  var tdee=Math.round(bmr*act);
  document.getElementById('calVal').textContent=tdee;
  document.getElementById('calBMR').textContent=bmr;
}
function selOpt(el,key,val){
  el.parentElement.querySelectorAll('.qopt').forEach(function(o){o.classList.remove('sel')});
  el.classList.add('sel');qAnswers[key]=val;
}
function goQ(step){
  document.querySelectorAll('.quiz-step').forEach(function(s){s.classList.remove('active')});
  var el=document.getElementById('qs'+step);
  if(el)el.classList.add('active');
  var pct=Math.round((step/5)*100);
  document.getElementById('qbar').style.width=pct+'%';
  document.getElementById('qctr').textContent='Întrebarea '+step+' din 5';
}
function finishQ(){
  document.querySelectorAll('.quiz-step').forEach(function(s){s.classList.remove('active')});
  document.getElementById('qs-r').classList.add('active');
  document.getElementById('qbar').style.width='100%';
  document.getElementById('qctr').textContent=tr('quiz_completed');
  var g=qAnswers.goal||'slabire';
  var titles={slabire:tr('quiz_program_slim'),tonus:tr('quiz_program_tone'),masa:tr('quiz_program_mass'),sanatate:tr('quiz_program_wellness')};
  var descs={
    slabire:'Pe baza răspunsurilor tale, programul ideal combină cardio + forță și un plan nutrițional cu deficit caloric controlat. Rezultate vizibile în 6–8 săptămâni.',
    tonus:'Corpul tău are nevoie de antrenament cu greutăți moderate și repetări mai multe, combinat cu un plan proteic. Tonifiere vizibilă în 4–6 săptămâni.',
    masa:'Recomandăm un program de hipertrofie cu progresie de volum și surplus caloric de 200–300 kcal/zi. Rezultate în 8–12 săptămâni.',
    sanatate:'Programul optim combină mișcare regulată (150 min/săpt), nutriție echilibrată și monitorizarea biomarkerilor. Focus pe energie și bunăstare.'
  };
  var specialistInfo={
    slabire:{name:'Ana-Maria Ciobanu',role:'Antrenor IFBB - Slăbire & Tonifiere',desc:'Specializare în pierderea de greutate sănătoasă. Peste 150 cliente au slăbit cu ea. Metodă proven: cardio+strength+nutriție. 6-8 săptămâni pentru rezultate vizibile.',photo:'data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 400 600%27%3E%3Crect fill=%27%23171A21%27 width=%27400%27 height=%27600%27/%3E%3Ccircle cx=%27200%27 cy=%27150%27 r=%2760%27 fill=%27%23D4AF37%27/%3E%3Crect x=%2780%27 y=%27240%27 width=%27240%27 height=%27280%27 fill=%271E222B%27/%3E%3C/svg%3E'},
    tonus:{name:'Ana-Maria Ciobanu',role:'Antrenor IFBB - Tonifiere',desc:'Expert în tonifierea corpului fără excese. Programe adaptive. Rezultate în 4-6 săptămâni cu abordare personalizată.',photo:'data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 400 600%27%3E%3Crect fill=%27%23171A21%27 width=%27400%27 height=%27600%27/%3E%3Ccircle cx=%27200%27 cy=%27150%27 r=%2760%27 fill=%27%23D4AF37%27/%3E%3Crect x=%2780%27 y=%27240%27 width=%27240%27 height=%27280%27 fill=%271E222B%27/%3E%3C/svg%3E'},
    masa:{name:'Ana-Maria Ciobanu',role:'Antrenor IFBB - Masă Musculară',desc:'Specialitate: construirea masei musculare lean. Planuri de antrenament avansate cu progresie sistematică. 8-12 săptămâni pentru rezultate',photo:'data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 400 600%27%3E%3Crect fill=%27%23171A21%27 width=%27400%27 height=%27600%27/%3E%3Ccircle cx=%27200%27 cy=%27150%27 r=%2760%27 fill=%27%23D4AF37%27/%3E%3Crect x=%2780%27 y=%27240%27 width=%27240%27 height=%27280%27 fill=%271E222B%27/%3E%3C/svg%3E'},
    sanatate:{name:'Olga',role:'Nutriționist Specialist - Wellness',desc:'Plan nutrițional complet, adaptabil stilului tău de viață. Monitorizare lunară a sănătății generale și energiei. Abordare holistică.',photo:'data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 400 600%27%3E%3Crect fill=%27%23171A21%27 width=%27400%27 height=%27600%27/%3E%3Ccircle cx=%27200%27 cy=%27150%27 r=%2760%27 fill=%27%23E8B4A8%27/%3E%3Crect x=%2780%27 y=%27240%27 width=%27240%27 height=%27280%27 fill=%271E222B%27/%3E%3C/svg%3E'}
  };
  document.getElementById('qrtitle').textContent=titles[g]||'Program Personalizat';
  document.getElementById('qrtext').textContent=descs[g]||'';
  var spec=specialistInfo[g]||specialistInfo.slabire;
  document.getElementById('specialist-photo').src=spec.photo;
  document.getElementById('specialist-name').textContent=spec.name;
  document.getElementById('specialist-role').textContent=spec.role;
  document.getElementById('specialist-desc').textContent=spec.desc;
  showToast('Răspunsurile salvate în CRM!');
}
function resetQ(){
  qAnswers={};
  document.querySelectorAll('.qopt').forEach(function(o){o.classList.remove('sel')});
  document.querySelectorAll('.quiz-step').forEach(function(s){s.classList.remove('active')});
  document.getElementById('qs1').classList.add('active');
  document.getElementById('qbar').style.width='20%';
  document.getElementById('qctr').textContent='Întrebarea 1 din 5';
}
function renderSlots(){
  var g=document.getElementById('slotsGrid');
  g.innerHTML=slots.map(function(s,i){
    var full=s.avail===0,few=s.avail<=2&&!full;
    return '<div class="slot'+(full?' full':'')+'" '+(full?'':'onclick="pickSlot('+i+')"')+' data-i="'+i+'">'
      +'<div class="slot-date">'+s.date+'</div>'
      +'<div class="slot-time">08:00 – 10:00</div>'
      +'<div class="slot-avail '+(full?'avail-none':few?'avail-few':'avail-ok')+'">'+(full?tr('slot_full'):tr('slot_available').replace('{count}',s.avail))+'</div>'
      +'</div>';
  }).join('');
}
function pickSlot(i){
  document.querySelectorAll('.slot').forEach(function(s){s.classList.remove('selected')});
  document.querySelector('.slot[data-i="'+i+'"]').classList.add('selected');
  selSlot=slots[i];selTime=null;
  var tp=document.getElementById('timePills');
  tp.innerHTML=times.map(function(t){
    return '<div class="time-pill" onclick="pickTime(this,\''+t+'\'">'+t+'</div>';
  }).join('');
  document.getElementById('timePicker').style.display='block';
  document.getElementById('bookForm').style.display='none';
  document.getElementById('bookConf').classList.remove('show');
}
function pickTime(el,t){
  document.querySelectorAll('.time-pill').forEach(function(p){p.classList.remove('sel')});
  el.classList.add('sel');selTime=t;
  document.getElementById('bookForm').style.display='block';
}
function confirmBook(){
  var name=document.getElementById('bn').value.trim();
  var phone=document.getElementById('bp').value.trim();
  if(!name||!phone){showToast('Completează numele și telefonul!');return;}
  document.getElementById('bookDetails').innerHTML='<strong>'+name+'</strong> · '+selSlot.date+' · '+selTime+'<br>Bulevardul Gagarin 14, Alexia Fitness & Wellness Club';
  document.getElementById('bookConf').classList.add('show');
  document.getElementById('bookForm').style.display='none';
  showToast('Programare confirmată! Notificare Telegram trimisă.');
}
function submitForm(){
  var name=document.getElementById('fn').value.trim();
  var phone=document.getElementById('fp').value.trim();
  var email=document.getElementById('fe').value.trim();
  var cons=document.getElementById('fcons').checked;
  var ok=true;
  ['en','ep','ee','econs'].forEach(function(id){document.getElementById(id).classList.remove('show')});
  if(!name){document.getElementById('en').classList.add('show');ok=false;}
  if(!phone||phone.length<9){document.getElementById('ep').classList.add('show');ok=false;}
  if(!email||!email.includes('@')){document.getElementById('ee').classList.add('show');ok=false;}
  if(!cons){document.getElementById('econs').classList.add('show');ok=false;}
  if(!ok)return;
  var btn=document.getElementById('fsubmit');
  btn.textContent='Se trimite...';btn.disabled=true;
  var newLead={
    id:crmLeads.length+1,name:name,phone:phone,
    goal:document.getElementById('fg').value||'Nespecificat',
    weight:(document.getElementById('fwc').value||'?')+'/'+(document.getElementById('fwt').value||'?'),
    date:new Date().toLocaleDateString('ro-MD',{day:'2-digit',month:'short'}),status:'new'
  };
  setTimeout(function(){
    crmLeads.unshift(newLead);
    document.getElementById('fContent').style.display='none';
    document.getElementById('fSuccess').classList.add('show');
    document.getElementById('sName').textContent=name;
    renderLeads();updateMetrics();
    showToast('Lead nou adăugat în CRM + notificare Telegram!');
  },1200);
}
function setFilter(f,btn){
  crmFilter=f;
  document.querySelectorAll('.fbtn').forEach(function(b){b.classList.remove('active')});
  btn.classList.add('active');renderLeads();
}
function renderLeads(){
  var search=document.getElementById('crmS').value.toLowerCase();
  var smap={new:'s-new',contacted:'s-contacted',scheduled:'s-scheduled',active:'s-active',done:'s-done'};
  var lmap={new:tr('crm_new'),contacted:tr('crm_contacted'),scheduled:tr('crm_scheduled'),active:tr('crm_active'),done:tr('crm_done')};
  var filtered=crmLeads.filter(function(l){
    var ms=crmFilter==='all'||l.status===crmFilter;
    var mq=!search||l.name.toLowerCase().includes(search)||l.phone.includes(search);
    return ms&&mq;
  });
  var tbody=document.getElementById('leadsBody');
  if(!filtered.length){tbody.innerHTML='';document.getElementById('noLeads').style.display='block';return;}
  document.getElementById('noLeads').style.display='none';
  tbody.innerHTML=filtered.map(function(l){
    return '<tr><td style="font-weight:500">'+l.name+'</td><td style="color:#a0845a">'+l.phone+'</td><td>'+l.goal+'</td><td style="color:var(--color-text-secondary)">'+l.weight+' kg</td><td style="color:var(--color-text-secondary)">'+l.date+'</td><td><span class="sbadge '+smap[l.status]+'">'+lmap[l.status]+'</span></td><td><button class="act-btn" onclick="changeStatus('+l.id+')">Status</button><button class="act-btn" onclick="showToast(\'Telegram: '+l.name.split(' ')[0]+'\')">TG</button></td></tr>';
  }).join('');
}
function changeStatus(id){
  var order=['new','contacted','scheduled','active','done'];
  var lead=crmLeads.find(function(l){return l.id===id});
  if(!lead)return;
  var i=order.indexOf(lead.status);
  lead.status=order[(i+1)%order.length];
  renderLeads();updateMetrics();showToast('Status actualizat!');
}
function updateMetrics(){
  var t=crmLeads.length;
  var n=crmLeads.filter(function(l){return l.status==='new'}).length;
  var a=crmLeads.filter(function(l){return l.status==='active'}).length;
  document.getElementById('mTotal').textContent=t;
  document.getElementById('mNew').textContent=n;
  document.getElementById('mActive').textContent=a;
  document.getElementById('mConv').textContent=(t?Math.round(a/t*100):0)+'%';
}
document.addEventListener('DOMContentLoaded',function(){
  renderSlots();calcIMC();calcCal();renderLeads();updateMetrics();
  document.querySelectorAll('.card').forEach(function(card,i){
    setTimeout(function(){card.style.animation='fadeIn 0.5s ease forwards'},i*50);
  });
});
window.addEventListener('scroll',function(){
  var nav=document.querySelector('.nav');
  nav.style.boxShadow=window.scrollY>20?'0 4px 12px rgba(0,0,0,0.08)':'0 2px 8px rgba(0,0,0,0.08)';
});

/* ═══════════════════════════════════════════════════════════════════════════ */
/* SCROLL REVEAL ANIMATIONS - Intersection Observer                             */
/* ═══════════════════════════════════════════════════════════════════════════ */
var revealElements=document.querySelectorAll('.sec');
var scrollRevealObserver=new IntersectionObserver(function(entries){
  entries.forEach(function(entry){
    if(entry.isIntersecting){
      entry.target.classList.add('visible');
      entry.target.style.animation='slideUpIn 0.8s cubic-bezier(0.34,1.56,0.64,1) forwards';
    }
  });
},{threshold:0.1,rootMargin:'0px 0px -80px 0px'});

revealElements.forEach(function(el){
  el.classList.add('scroll-reveal');
  scrollRevealObserver.observe(el);
});

/* Stagger effect for grid items */
var gridItems=document.querySelectorAll('.grid3 .card, .grid2 .card');
gridItems.forEach(function(item,i){
  item.style.setProperty('--delay',i*0.1+'s');
  item.style.animation='slideUpIn 0.8s cubic-bezier(0.34,1.56,0.64,1) '+i*0.1+'s both';
});

/* ═══════════════════════════════════════════════════════════════════════════ */
/* PARALLAX EFFECT - Hero visual layer                                          */
/* ═══════════════════════════════════════════════════════════════════════════ */
if(window.innerWidth>768){
  var heroVisual=document.querySelector('.hero-visual');
  if(heroVisual){
    window.addEventListener('scroll',function(){
      var scrolled=window.scrollY;
      heroVisual.style.transform='translateY('+scrolled*0.3+'px)';
    });
  }
}

/* ═══════════════════════════════════════════════════════════════════════════ */
/* SCROLL PROGRESS INDICATOR - Top bar                                          */
/* ═══════════════════════════════════════════════════════════════════════════ */
var progressBar=document.createElement('div');
progressBar.style.cssText='position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,#C8A24A 0%,#7EE0C3 100%);width:0;z-index:999;transition:width 0.1s ease';
document.body.appendChild(progressBar);

window.addEventListener('scroll',function(){
  var windowHeight=document.documentElement.scrollHeight-window.innerHeight;
  var scrolled=windowHeight>0?(window.scrollY/windowHeight)*100:0;
  progressBar.style.width=scrolled+'%';
});
</script>
<script src="i18n.js"></script>
